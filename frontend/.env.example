# Ever After Events — Frontend Environment Variables
# Copy to .env and fill in your values

# API URL
VITE_API_URL=https://ever-after-events-api.onrender.com/api/v1

# Cloudinary (for media optimization)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Site URL (Vercel in production)
VITE_SITE_URL=https://build-t-chall-tckt-kp-tech.vercel.app

# Sentry (optional)
VITE_SENTRY_DSN=your-sentry-dsn
